{
  "version": 2,
  "functions": {
    "api/predict.py": {
      "maxDuration": 30
    },
    "api/health.py": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "outputDirectory": "public"
}
